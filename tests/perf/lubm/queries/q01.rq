# LUBM Q1 — Graduate students taking a specific graduate course.
# Class membership lookup + literal property match.
# Reasoning profile sensitivity: none — both subjects and predicates are direct.

PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX ub:  <file:///opt/lubm/univ-bench.owl#>

SELECT ?x
WHERE {
  ?x rdf:type ub:GraduateStudent .
  ?x ub:takesCourse <http://www.Department0.University0.edu/GraduateCourse0> .
}
