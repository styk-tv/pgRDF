@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:TestShape
  rdf:type sh:NodeShape ;
  sh:maxInclusive 4 ;
  sh:targetClass ex:TestClass ;
  sh:targetNode ex:John ;
  sh:targetNode 3.9 ;
  sh:targetNode 4 ;
  sh:targetNode 4.0 ;
  sh:targetNode 4.1 ;
  sh:targetNode "Hello" ;
.
