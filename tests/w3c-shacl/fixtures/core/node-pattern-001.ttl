ex:TestShape
  rdf:type sh:NodeShape ;
  sh:pattern "^[2-8][0-9]*$" ;
  sh:targetClass ex:TestClass ;
  sh:targetNode ex:Test ;
  sh:targetNode 20000123 ;
  sh:targetNode "3456" ;
  sh:targetNode 39 ;
  sh:targetNode "777777"@mi ;
  sh:targetNode 9 ;
  sh:targetNode "John" ;
.
